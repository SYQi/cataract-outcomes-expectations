# Staff password for /admin and CSV export (defaults to 123 if unset)
ANALYTICS_ADMIN_PASSWORD=123

# On Vercel, connecting a Blob store usually injects BLOB_STORE_ID (OIDC).
# Older setups used BLOB_READ_WRITE_TOKEN instead. You do not need both.
# BLOB_STORE_ID=
# BLOB_READ_WRITE_TOKEN=

# Optional: force Blob access mode if saves fail ("private" or "public").
# Defaults to private when BLOB_STORE_ID is set, otherwise public.
# BLOB_ACCESS=private
